[debug] [2026-04-07T09:18:56.962Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/little-letters-514e3/rulesets {"name":"projects/little-letters-514e3/rulesets/b6fedf01-f1e4-499d-af09-114a08a2dce3","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    // Legacy collection (keep for backwards compatibility)\n    match /messages/{messageId} {\n      allow read, write: if request.auth != null;\n    }\n\n    // Users collection - users can read/write their own doc\n    match /users/{userId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth != null && request.auth.uid == userId;\n    }\n\n    // Messages collection - scoped to sender and receiver\n    match /messages/{messageId} {\n      allow read: if request.auth != null &&\n        (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);\n      allow create: if request.auth != null &&\n        request.auth.uid == request.resource.data.fromUid;\n      allow update: if request.auth != null &&\n        (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-07T09:18:57.398927Z","metadata":{"services":["cloud.firestore"]}}

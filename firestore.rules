rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId || 
        // Pairing: Allow if partnerId is null/missing and setting to current user, but change NOTHING else
        (resource.data.get('partnerId', null) == null && 
         request.resource.data.partnerId == request.auth.uid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerId', 'pairedAt'])) ||
        // Unpairing: Allow if current user is the partner and clearing it, but change NOTHING else
        (resource.data.partnerId == request.auth.uid && 
         (request.resource.data.get('partnerId', null) == null || !('partnerId' in request.resource.data)) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['partnerId', 'pairedAt']))
      );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /messages/{messageId} {
      // Allow fetching a single message if you are the sender or receiver
      allow get: if request.auth != null &&
        (request.auth.uid == resource.data.receiverId || 
         request.auth.uid == resource.data.senderId);
      
      // Allow querying messages where you are either the sender or receiver
      allow list: if request.auth != null &&
        (request.auth.uid == resource.data.receiverId || 
         request.auth.uid == resource.data.senderId);

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.senderId &&
        request.resource.data.receiverId is string &&
        request.resource.data.senderId is string;

      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.receiverId ||
         request.auth.uid == resource.data.senderId);

      // Reactions subcollection
      match /reactions/{reactionId} {
        allow read: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/messages/$(messageId)).data.senderId ||
          request.auth.uid == get(/databases/$(database)/documents/messages/$(messageId)).data.receiverId
        );
        allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
        allow update: if request.auth != null && request.auth.uid == resource.data.userId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }

      // Replies subcollection
      match /replies/{replyId} {
        allow read: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/messages/$(messageId)).data.senderId ||
          request.auth.uid == get(/databases/$(database)/documents/messages/$(messageId)).data.receiverId
        );
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && request.auth.uid == resource.data.userId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
      }
    }

    // Games collection - 2 players only, restricted read/write
    match /games/{gameId} {
      // Allow read if you are a participant OR the game is waiting (so 2nd player can find it)
      // Fallback: allow if you are the creator (handles initialization quirks)
      allow read: if request.auth != null && (
        resource.data.status == 'waiting' ||
        request.auth.uid in resource.data.players ||
        request.auth.uid == resource.data.creatorUid
      );

      allow create: if request.auth != null;

      // Allow update if already a player, OR if you are joining as 2nd player
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.get('players', []) ||
        // Joining: status must be waiting, and current user must be adding themselves to players
        (resource.data.status == 'waiting' &&
         resource.data.get('players', []).size() <= 1 &&
         request.resource.data.players.size() == 2 &&
         request.resource.data.players.hasAll(resource.data.get('players', [])) &&
         request.auth.uid in request.resource.data.players)
      );

      // Private hands — only the owner can read their own hand.
      // During the join phase (status='waiting'), the joining player can write both to hands
      // because the batch atomically sets up the initial deal before status flips to 'playing'.
      match /hands/{userId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && (
          request.auth.uid == userId ||
          get(/databases/$(database)/documents/games/$(gameId)).data.status == 'waiting' ||
          request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.players
        );
      }

      // Hidden deck — players can 'get' a specific card by index but cannot 'list' the full pile.
      // Writing is allowed during the join phase (status='waiting') so the deal can be set up.
      match /deck/{cardId} {
        allow get: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.players;
        allow write: if request.auth != null && (
          request.auth.uid in get(/databases/$(database)/documents/games/$(gameId)).data.players ||
          get(/databases/$(database)/documents/games/$(gameId)).data.status == 'waiting'
        );
        allow list: if false;
      }
    }

    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /notifications/{toUid} {
      allow read: if request.auth != null && request.auth.uid == toUid;
      match /items/{notifId} {
        allow read: if request.auth != null && request.auth.uid == toUid;
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == toUid;
        allow delete: if request.auth != null && request.auth.uid == toUid;
      }
    }

    match /moments/{momentId} {
      // 'get' can scope by resource.data, 'list' cannot - pairId query is the access control
      allow get: if request.auth != null &&
        (resource.data.userId == request.auth.uid || resource.data.partnerId == request.auth.uid);
      // Allow list for any authenticated user - the pairId field restricts results at query level
      allow list: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}